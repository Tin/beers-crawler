# Copy to deploy/deploy.env (gitignored) and fill in your host.
# Used only by scripts/deploy.sh on your laptop — never shipped as secrets.

# SSH target (user@host)
DEPLOY_HOST=you@your-server.example

# Absolute path on the server where the app is installed
DEPLOY_ROOT=/var/www/beers-crawler

# Public site origin(s) for CORS seed (comma-separated), optional
DEPLOY_PUBLIC_ORIGINS=https://www.example.com,https://example.com

# Public base URL for post-deploy smoke checks (no trailing slash), optional
DEPLOY_PUBLIC_BASE=https://www.example.com/beers/rating

# nginx site config to patch (server block that serves the public host)
DEPLOY_NGINX_SITE_CONF=/etc/nginx/sites-enabled/example.com.conf

# server_name line to match when inserting the include (first match only)
DEPLOY_NGINX_SERVER_NAME=www.example.com

# Linux user/group that runs the API (must exist on the server)
DEPLOY_SERVICE_USER=www-data
DEPLOY_SERVICE_GROUP=www-data
