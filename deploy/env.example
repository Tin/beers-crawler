# Runtime env for the API process on the server.
# Deploy seeds this file once at $DEPLOY_ROOT/env and never overwrites it.
#
***REMOVED*** below are examples — deploy.sh rewrites BEERS_CRAWLER_DB from DEPLOY_ROOT.

BEERS_CRAWLER_DB=/var/www/beers-crawler/data/beers.db
BEERS_CRAWLER_PREFER_HTTPX=1
# 0 = never launch Chromium (use external search fallback for resolve)
BEERS_CRAWLER_ALLOW_PLAYWRIGHT=0
BEERS_CRAWLER_MIN_REFRESH_SECONDS=21600
# BEERS_CRAWLER_HEADED=0
# BEERS_CRAWLER_CORS=https://www.example.com,https://example.com
#
# Auth: create users with CLI (hashes stored in SQLite api_users — never commit passwords):
#   beers-crawler user add <username>
#   beers-crawler user passwd <username>
# Optional env bootstrap (prefer CLI users instead):
# BEERS_CRAWLER_API_USER=
# BEERS_CRAWLER_API_PASSWORD=
# Local dev only:
# BEERS_CRAWLER_AUTH_DISABLED=1
#
# Optional LLM keyword expansion (DeepSeek OpenAI-compatible). Never commit keys.
# BEERS_CRAWLER_LLM_API_KEY=
# BEERS_CRAWLER_LLM_BASE_URL=https://api.deepseek.com
# BEERS_CRAWLER_LLM_MODEL=deepseek-chat
# BEERS_CRAWLER_LLM_ENABLED=1
# BEERS_CRAWLER_LLM_TIMEOUT=12
